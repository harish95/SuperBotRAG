# Copy this file to .env and fill in real values. .env is git-ignored.
# docker-compose loads this into the backend via `env_file: .env`.

# ---- Runtime ----
# "local" relaxes admin-password / jwt-secret checks for dev.
# Set to "production" on AWS to enforce strong secrets.
ENVIRONMENT=local

# ---- OpenAI ----
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_DIMENSIONS=1536

# ---- Embedding / reranking models ----
SPARSE_MODEL=Qdrant/bm25
RERANKER_MODEL=BAAI/bge-reranker-base

# ---- Auth ----
JWT_SECRET=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=120
CORS_ORIGINS=http://localhost:5173

# ---- Admin account (seeded on startup) ----
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
ADMIN_FULL_NAME=RAG Administrator

# ---- Guardrails ----
GUARDRAILS_ENABLED=true
GUARDRAILS_MODEL=gpt-4o-mini
GUARDRAILS_MAX_INPUT_CHARS=2000
GUARDRAILS_MIN_RETRIEVED_DOCS=1
GUARDRAILS_BLOCK_PII_OUTPUT=true
GUARDRAILS_FAIL_OPEN=true

# ---- DynamoDB ----
DYNAMODB_USERS_TABLE=enterprise-rag-users
DYNAMODB_CHAT_LOGS_TABLE=enterprise-rag-chat-logs
DYNAMODB_DOCUMENTS_TABLE=enterprise-rag-documents
# Leave empty for real AWS; docker-compose overrides this to the local service.
DYNAMODB_ENDPOINT_URL=
DYNAMODB_AUTO_CREATE_TABLES=true

# ---- Redis ----
REDIS_URL=redis://localhost:6379
REDIS_CACHE_INDEX=faq_cache_idx
REDIS_CACHE_PREFIX=faq:
REDIS_CACHE_TTL_SECONDS=86400
REDIS_CACHE_DISTANCE_THRESHOLD=0.12

# ---- Qdrant ----
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=enterprise_rag
QDRANT_PREFER_GRPC=false

# ---- AWS / S3 (use minioadmin for the local MinIO stack) ----
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=rag-documents
S3_ENDPOINT_URL=http://localhost:9000
S3_USE_SSL=false
S3_AUTO_CREATE_BUCKET=true

# ---- Chunking / retrieval ----
PARENT_CHUNK_SIZE=1800
PARENT_CHUNK_OVERLAP=200
CHILD_CHUNK_SIZE=400
CHILD_CHUNK_OVERLAP=60
RETRIEVAL_TOP_K=12
RERANK_TOP_N=4
